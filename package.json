{
  "name": "cypress-login-practice",
  "version": "1.0.0",
  "description": "Pruebas E2E de login en Practice Test Automation con Cypress",
  "scripts": {
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:run:chrome": "cypress run --browser chrome",
    "cypress:run:firefox": "cypress run --browser firefox",
    "test": "npm run test:unit && npm run test:e2e",
    "test:e2e": "cypress run",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "ci": "npm run lint && npm run test:unit && npm run test:e2e",
    "test:report": "cypress run && npm run report:merge",
    "report:merge": "mochawesome-merge cypress/reports/mochawesome*.json -o cypress/reports/mochawesome-merged.json && marge cypress/reports/mochawesome-merged.json -f report -o cypress/reports/html",
    "lint": "eslint cypress/ vitest.config.js",
    "lint:fix": "eslint cypress/ vitest.config.js --fix",
    "format": "prettier --write \"cypress/**/*.{js,json}\" \"vitest.config.js\" \"cypress.config.js\"",
    "format:check": "prettier --check \"cypress/**/*.{js,json}\" \"vitest.config.js\" \"cypress.config.js\""
  },
  "keywords": ["cypress", "e2e", "login", "qa"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "lint-staged": {
    "cypress/**/*.{js,json}": [
      "eslint --fix",
      "prettier --write"
    ],
    "vitest.config.js": [
      "prettier --write"
    ],
    "cypress.config.js": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "cypress": "^15.15.0",
    "dotenv": "^16.4.7",
    "eslint": "^10.4.0",
    "eslint-plugin-cypress": "^6.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2",
    "prettier": "^3.8.3",
    "vitest": "^3.0.5"
  }
}
